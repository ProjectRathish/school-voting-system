# ─── Database ────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_USER=your_db_user
DB_PASSWORD=your_strong_db_password
DB_NAME=school_voting_system

# ─── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Auth ────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
JWT_SECRET=change_this_to_a_very_long_random_secret_key_min_32_chars

# ─── CORS: Allow only your frontend subdomain ─────────────────
FRONTEND_URL=https://election.issschoolpmna.in
